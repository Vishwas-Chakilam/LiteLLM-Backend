# Tester authentication removed — endpoints are open for now

# Fast tier — cheap models
# Groq models use groq/ prefix; Gemini models use gemini/ prefix
FAST_MODEL_1=groq/llama-3.1-8b-instant
FAST_API_KEY_1=gsk_your-groq-key
FAST_MODEL_2=gemini/gemini-2.5-flash-lite
FAST_API_KEY_2=AIza_your-gemini-key
FAST_MODEL_3=gemini/gemini-2.5-flash
FAST_API_KEY_3=AIza_your-gemini-key

# Capable tier — expensive models
CAPABLE_MODEL_1=groq/llama-3.3-70b-versatile
CAPABLE_API_KEY_1=gsk_your-groq-key

# Optional: second keys for load balancing / failover
# FAST_MODEL_2=groq/llama-3.1-8b-instant
# FAST_API_KEY_2=gsk_...
# CAPABLE_MODEL_2=anthropic/claude-3-5-sonnet-20241022
# CAPABLE_API_KEY_2=sk-ant-...

# Router behavior
ROUTING_STRATEGY=simple-shuffle
NUM_RETRIES=2
ALLOWED_FAILS=3
COOLDOWN_TIME=60

# Cost guards
DAILY_BUDGET_USD=10.00
PER_CONVERSATION_BUDGET_USD=0.50
MAX_INPUT_TOKENS=8000
MAX_OUTPUT_TOKENS=2000

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# Storage
DATA_DIR=data/conversations

# Safety system prompt (server-side, every conversation)
SYSTEM_PROMPT_ENABLED=true
